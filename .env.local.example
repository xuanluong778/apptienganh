## Copy to .env.local and fill values

# Voice WS SaaS
REDIS_URL=redis://127.0.0.1:6379
VOICE_JWT_SECRET=REPLACE_WITH_RANDOM_32+_BYTES_BASE64URL

# OpenAI (server-side workers)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_CHAT_MODEL=gpt-4o-mini

# Azure STT (optional, for voice STT)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# VBEE TTS — đọc giải thích tiếng Việt trên /lessons (https://studio.vbee.vn/apps)
# Realtime (sync): bắt buộc dùng api.vbee.vn — KHÔNG dùng https://vbee.vn/api/v1 cho chat ngắn
VBEE_API_TOKEN=
VBEE_TOKEN=
VBEE_APP_ID=
VBEE_USER_ID=
VBEE_VOICE_CODE=hn_female_ngochuyen_full_48k-fhg
VBEE_API_URL=https://api.vbee.vn/v1/tts
# Cache MP3 trên đĩa — không gọi lại VBEE khi cùng nội dung + giọng (mặc định: .cache/vbee-tts)
# VBEE_CACHE_DIR=

# DB (example)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
# Tên database trong Laragon/phpMyAdmin (ví dụ: apptienganh)
DB_NAME=apptienganh

